# ~/.zshenv_common
# Common environment for interactive and non-interactive shells.
# Helper: prepend a directory to PATH if not already present
path_prepend() {
  case ":$PATH:" in
    *":$1:"*) return ;;
    *) PATH="$1:$PATH" ;;
  esac
}

# MUST be first: pyenv controls the default Python version.
# Project envs and package management are handled with uv.
if command -v pyenv >/dev/null 2>&1; then
  path_prepend "$(pyenv root)/shims"
fi

# Basic user bins
path_prepend "$HOME/bin"
path_prepend "$HOME/.local/bin"
path_prepend "/Applications/Visual Studio Code.app/Contents/Resources/app/bin"
path_prepend "/Applications/SnowflakeCLI.app/Contents/MacOS"

# jenv binary location (init is interactive-only below)
path_prepend "$HOME/.jenv/bin"

# Export locale
export LC_ALL=en_US.UTF-8
export LANG=en_US.UTF-8

export PATH

# Optional: load env vars
[ -f "$HOME/.env_vars" ] && source "$HOME/.env_vars"
